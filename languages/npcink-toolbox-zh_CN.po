msgstr "FAQ 与摘要"

msgid "AEO rules"
msgstr "AEO 规则"

msgid "Start with a direct answer, then add conditions, steps, limits, and short followups."
msgstr "先给出直接回答，再补充条件、步骤、限制和简短追问。"

msgid "Allow FAQ suggestions"
msgstr "允许 FAQ 建议"

msgid "Allow AEO answer summary suggestions"
msgstr "允许 AEO 回答摘要建议"

msgid "AEO fields AI may suggest"
msgstr "AI 可以建议的 AEO 字段"

msgid "Guide AI-readable entity signals, standalone conclusions, and citation-friendly summaries."
msgstr "指导 AI 可读的实体信号、独立结论和便于引用的摘要。"

msgid "GEO fields"
msgstr "GEO 字段"

msgid "Entities"
msgstr "实体"

