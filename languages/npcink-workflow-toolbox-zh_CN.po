msgstr "Toolbox 已为当前单篇文章准备 SEO 标题和描述候选，需交由 Core 治理审核。"

msgid "SEO title candidate"
msgstr "SEO 标题候选"

msgid "SEO description candidate"
msgstr "SEO 描述候选"

