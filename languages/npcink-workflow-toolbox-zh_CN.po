msgstr "相关文章"

msgid "Site Knowledge returned this internal target with similarity score %s. Review relevance before inserting manually."
msgstr "Site Knowledge 返回了这个内链目标，相似度分数为 %s。手动插入前请审阅相关性。"

msgid "Site Knowledge returned this as related public content. Review relevance before inserting manually."
msgstr "Site Knowledge 将它作为相关公开内容返回。手动插入前请审阅相关性。"

