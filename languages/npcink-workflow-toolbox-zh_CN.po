msgid "Npcink Workflow Toolbox"
msgstr "Npcink Workflow Toolbox"

msgid "Settings"
msgstr "设置"

msgid "Toolbox"
msgstr "工具箱"

msgid "Operator-facing AI tools for Cloud-managed web search, Cloud-managed image-source candidates, Qdrant vector search, and repeatable content workflows."
msgstr "面向运营者的 AI 工具，用于云端托管网页搜索、云端托管图片来源候选、Qdrant 向量搜索和可重复的内容工作流。"

msgid "You do not have permission to access this page."
msgstr "你没有权限访问此页面。"

msgid "Running..."
msgstr "正在运行..."

msgid "Request failed."
msgstr "请求失败。"

msgid "Use hosted AI for reviewable content-support suggestions, then hand final WordPress writes to Core proposal approval."
msgstr "使用托管 AI 生成可审阅的内容支持建议，最终 WordPress 写入仍交由 Core 提案审批。"

msgid "Toolbox sections"
msgstr "工具箱分区"

msgid "Content Context"
msgstr "内容上下文"

msgid "Fill a compact site brief, then tune SEO, AEO, and GEO guidance. Draft buttons only prefill this form; nothing is saved until you click Save content context. After saving, use Content Support to test briefs, site knowledge, and image candidates."
msgstr "先填写一份精简站点简报，再调整 SEO、AEO 和 GEO 指引。草稿按钮只会预填此表单；点击保存内容上下文之前不会保存任何内容。保存后，可使用内容支持测试简报、站点知识和图片候选。"

msgid "Content context draft actions"
msgstr "内容上下文草稿操作"

msgid "Use AI tech blog template"
msgstr "使用 AI 技术博客模板"

msgid "Draft from current site content"
msgstr "根据当前站点内容生成草稿"

msgid "Clear form"
msgstr "清空表单"

msgid "Drafts are editable suggestions and do not change posts, media, SEO meta, or provider settings."
msgstr "草稿只是可编辑建议，不会更改文章、媒体、SEO 元数据或提供方设置。"

msgid "Content context sections"
msgstr "内容上下文分区"

msgid "Brief"
msgstr "简报"

msgid "Start here"
msgstr "从这里开始"

msgid "SEO"
msgstr "SEO"

msgid "Search snippets"
msgstr "搜索摘要"

msgid "AEO"
msgstr "AEO"

msgid "Answer shape"
msgstr "回答结构"

msgid "GEO"
msgstr "GEO"

msgid "AI citation signals"
msgstr "AI 引用信号"

msgid "Boundaries"
msgstr "边界"

msgid "Claims and preview"
msgstr "声明与预览"

msgid "Define who the site is for and how suggestions should sound. This is the minimum useful setup."
msgstr "定义站点面向谁，以及建议应采用什么表达方式。这是最低限度的有效设置。"

msgid "Brief fields"
msgstr "简报字段"

msgid "Site profile"
msgstr "站点画像"

msgid "Positioning"
msgstr "定位"

msgid "Audience"
msgstr "受众"

msgid "Readers"
msgstr "读者"

msgid "Voice"
msgstr "语气"

msgid "Tone"
msgstr "语气"

msgid "Keywords"
msgstr "关键词"

msgid "Primary terms"
msgstr "核心词"

msgid "Tell AI what this site is, who it helps, and what kind of suggestion it should produce first."
msgstr "告诉 AI 这个站点是什么、服务谁，以及应优先生成哪类建议。"

msgid "Site positioning"
msgstr "站点定位"

msgid "List the reader groups AI should optimize explanations, examples, and terminology for."
msgstr "列出 AI 在解释、示例和术语上应优先适配的读者群体。"

msgid "Target audience"
msgstr "目标受众"

msgid "Set the writing posture, level of detail, and phrases AI should favor or avoid."
msgstr "设置写作姿态、细节程度，以及 AI 应偏好或避免的表达。"

msgid "Brand voice"
msgstr "品牌语气"

msgid "Use this short list as the main topic vocabulary before adding SEO-specific long-tail terms."
msgstr "先把这份短列表作为主要主题词汇，再补充 SEO 专用长尾词。"

msgid "Primary keywords"
msgstr "主要关键词"

msgid "Control search-oriented metadata, keyword coverage, and which SEO fields AI may suggest."
msgstr "控制面向搜索的元数据、关键词覆盖范围，以及 AI 可以建议哪些 SEO 字段。"

msgid "SEO fields"
msgstr "SEO 字段"

msgid "Long-tail terms"
msgstr "长尾词"

msgid "Rules"
msgstr "规则"

msgid "Search guidance"
msgstr "搜索指引"

msgid "Suggestion fields"
msgstr "建议字段"

msgid "Allowed output"
msgstr "允许输出"

msgid "SEO keywords"
msgstr "SEO 关键词"

msgid "Add supporting long-tail phrases here. Primary keywords stay in the Brief section so the first setup path remains obvious."
msgstr "在这里添加辅助长尾短语。主要关键词保留在简报分区，让首次设置路径保持清晰。"

msgid "Long-tail keywords"
msgstr "长尾关键词"

msgid "SEO rules"
msgstr "SEO 规则"

msgid "Describe title, description, slug, excerpt, and internal-link preferences for proposal-ready suggestions."
msgstr "描述标题、描述、别名、摘要和内链偏好，用于生成可进入提案的建议。"

msgid "SEO fields AI may suggest"
msgstr "AI 可以建议的 SEO 字段"

msgid "Shape answer-engine output: direct answers, FAQs, definitions, and step-style responses."
msgstr "塑造回答引擎输出：直接回答、FAQ、定义和步骤式回答。"

msgid "AEO fields"
msgstr "AEO 字段"

msgid "Answer guidance"
msgstr "回答指引"

msgid "Output toggles"
msgstr "输出开关"

msgid "FAQ and summary"
msgstr "FAQ 与摘要"

msgid "AEO rules"
msgstr "AEO 规则"

msgid "Start with a direct answer, then add conditions, steps, limits, and short followups."
msgstr "先给出直接回答，再补充条件、步骤、限制和简短追问。"

msgid "Allow FAQ suggestions"
msgstr "允许 FAQ 建议"

msgid "Allow AEO answer summary suggestions"
msgstr "允许 AEO 回答摘要建议"

msgid "AEO fields AI may suggest"
msgstr "AI 可以建议的 AEO 字段"

msgid "Guide AI-readable entity signals, standalone conclusions, and citation-friendly summaries."
msgstr "指导 AI 可读的实体信号、独立结论和便于引用的摘要。"

msgid "GEO fields"
msgstr "GEO 字段"

msgid "Entities"
msgstr "实体"

msgid "Signals"
msgstr "信号"

msgid "Summary guidance"
msgstr "摘要指引"

msgid "GEO and schema"
msgstr "GEO 与 schema"

msgid "List people, products, standards, projects, and concepts AI should recognize as important context."
msgstr "列出 AI 应识别为重要上下文的人物、产品、标准、项目和概念。"

msgid "Entity keywords"
msgstr "实体关键词"

msgid "GEO rules"
msgstr "GEO 规则"

msgid "Keep key conclusions standalone, define important entities, and separate implemented facts from plans."
msgstr "让关键结论可以独立引用，定义重要实体，并区分已实现事实和计划。"

msgid "Allow GEO summary suggestions"
msgstr "允许 GEO 摘要建议"

msgid "Allow structured data suggestions"
msgstr "允许结构化数据建议"

msgid "GEO fields AI may suggest"
msgstr "AI 可以建议的 GEO 字段"

msgid "Limit what AI can claim and inspect the read-only payload exposed to callers."
msgstr "限制 AI 可以声称的内容，并检查暴露给调用方的只读载荷。"

msgid "Boundary fields"
msgstr "边界字段"

msgid "Allowed claims"
msgstr "允许声明"

msgid "Can say"
msgstr "可以说"

msgid "Forbidden claims"
msgstr "禁止声明"

msgid "Must not say"
msgstr "不能说"

msgid "Exceptions"
msgstr "例外"

msgid "Special cases"
msgstr "特殊情况"

msgid "Ability preview"
msgstr "能力预览"

msgid "Read-only payload"
msgstr "只读载荷"

msgid "Disallowed topics"
msgstr "禁止主题"

msgid "Cautious topics"
msgstr "谨慎主题"

msgid "No structured output topics"
msgstr "不生成结构化输出的主题"

msgid "Human confirmation required"
msgstr "需要人工确认"

msgid "Final WordPress writes still require Core proposal approval; third-party AI receives this context as suggestion-only guidance."
msgstr "最终 WordPress 写入仍需要 Core 提案审批；第三方 AI 只会把此上下文作为建议性指引接收。"

msgid "Save content context"
msgstr "保存内容上下文"

msgid "SEO title"
msgstr "SEO 标题"

msgid "SEO description"
msgstr "SEO 描述"

msgid "Slug"
msgstr "别名"

msgid "Excerpt"
msgstr "摘要"

msgid "FAQ"
msgstr "FAQ"

msgid "Answer summary"
msgstr "回答摘要"

msgid "GEO summary"
msgstr "GEO 摘要"

msgid "Structured data hints"
msgstr "结构化数据提示"

msgid "Save and verify Cloud Addon credentials to enable hosted execution."
msgstr "保存并验证 Cloud Addon 凭据以启用托管执行。"

msgid "Check Cloud Addon transport before running hosted execution."
msgstr "运行托管执行前请检查 Cloud Addon 传输。"

msgid "Site Knowledge"
msgstr "站点知识"

msgid "Start or refresh Cloud-managed indexing for public site content. Toolbox sends the manifest; Cloud owns embeddings, vector storage, rerank, and run detail."
msgstr "为公开站点内容启动或刷新 Cloud 托管索引。Toolbox 发送清单；Cloud 拥有嵌入、向量存储、重排和运行详情。"

msgid "Index status"
msgstr "索引状态"

msgid "Read-only Cloud coverage summary for this WordPress site."
msgstr "此 WordPress 站点的只读 Cloud 覆盖摘要。"

msgid "Refresh status"
msgstr "刷新状态"

msgid "Connect Cloud Addon before reading Site Knowledge coverage."
msgstr "读取站点知识覆盖范围前请先连接 Cloud Addon。"

msgid "Status has not been loaded yet."
msgstr "状态尚未加载。"

msgid "Index actions"
msgstr "索引操作"

msgid "Create or refresh the Cloud index for current public site content. Advanced cleanup stays in Cloud operations."
msgstr "为当前公开站点内容创建或刷新 Cloud 索引。高级清理仍由 Cloud 运维处理。"

msgid "Toolbox sends the latest public posts and pages. Approved comments are included only when Cloud comments indexing is enabled."
msgstr "Toolbox 会发送最新公开文章和页面。只有启用 Cloud 评论索引时，才会包含已批准评论。"

msgid "Start indexing"
msgstr "开始索引"

msgid "Refresh index"
msgstr "刷新索引"

msgid "Indexing is disabled until Cloud Addon transport is available."
msgstr "Cloud Addon 传输可用前，索引功能处于禁用状态。"

msgid "Used by Content Support"
msgstr "由内容支持使用"

msgid "After the index is ready, these Toolbox actions can use Cloud Site Knowledge automatically."
msgstr "索引就绪后，这些 Toolbox 操作可以自动使用 Cloud 站点知识。"

msgid "Open Content Support"
msgstr "打开内容支持"

msgid "Internal Link Candidates"
msgstr "内链候选"

msgid "Find related public posts and pages for editor-reviewed links."
msgstr "为编辑审阅的链接查找相关公开文章和页面。"

msgid "Publish Preflight"
msgstr "发布预检"

msgid "Check duplicate risk, source coverage, and missing site references before publishing."
msgstr "发布前检查重复风险、来源覆盖和缺失的站点引用。"

msgid "Discoverability Brief"
msgstr "可发现性简报"

msgid "Ground SEO, AEO, and GEO suggestions in existing site context."
msgstr "基于现有站点上下文生成 SEO、AEO 和 GEO 建议。"

msgid "External AI workflows"
msgstr "外部 AI 工作流"

msgid "Use the same Cloud-managed knowledge ability for API callers and natural-language requests."
msgstr "API 调用方和自然语言请求使用同一个 Cloud 托管知识能力。"

msgid "Use the same Cloud-managed knowledge ability for planning bundles and natural-language requests."
msgstr "规划包和自然语言请求使用同一个 Cloud 托管知识能力。"

msgid "Final WordPress edits still require the normal Core proposal and editor approval path."
msgstr "最终 WordPress 编辑仍需要常规 Core 提案和编辑审批路径。"

msgid "Advanced search check"
msgstr "高级搜索检查"

msgid "Search check"
msgstr "搜索检查"

msgid "Run a read-only query against Cloud-managed site knowledge."
msgstr "对 Cloud 托管站点知识运行只读查询。"

msgid "Connect Cloud Addon before running Site Knowledge checks."
msgstr "运行站点知识检查前请先连接 Cloud Addon。"

msgid "Query"
msgstr "查询"

msgid "Search public site knowledge"
msgstr "搜索公开站点知识"

msgid "Intent"
msgstr "意图"

msgid "Site search"
msgstr "站点搜索"

msgid "FAQ candidates"
msgstr "FAQ 候选"

msgid "Content gaps"
msgstr "内容缺口"

msgid "Internal links"
msgstr "内链"

msgid "Source types"
msgstr "来源类型"

msgid "Current post ID"
msgstr "当前文章 ID"

msgid "Max results"
msgstr "最大结果数"

msgid "Search index"
msgstr "搜索索引"

msgid "Run check"
msgstr "运行检查"

msgid "Content Support"
msgstr "内容支持"

msgid "Writing Support"
msgstr "写作辅助"

msgid "Titles, summaries, outlines, and paragraph review for human-written articles."
msgstr "为人工撰写的文章提供标题、摘要、大纲和段落审阅。"

msgid "Title suggestions"
msgstr "标题建议"

msgid "Generate reviewable title options from the current draft context."
msgstr "根据当前草稿上下文生成可审阅的标题选项。"

msgid "Outline suggestions"
msgstr "大纲建议"

msgid "Build a compact outline that an editor can expand manually."
msgstr "生成一份编辑可手动扩展的精简大纲。"

msgid "Review selected paragraph"
msgstr "段落审阅"

msgid "Review clarity, fact boundaries, and tone for the selected paragraph. It will not rewrite text."
msgstr "审阅选中段落的清晰度、事实边界和语气，不改写正文。"

msgid "Select paragraph text before running paragraph review."
msgstr "请先选择段落文字再运行段落审阅。"

msgid "Paragraph review"
msgstr "段落审阅"

msgid "Clarity check"
msgstr "清晰度检查"

msgid "Fact gaps"
msgstr "事实缺口"

msgid "Tone consistency"
msgstr "语气一致性"

msgid "Editing suggestions"
msgstr "编辑建议"

msgid "Assumptions to verify"
msgstr "待核实假设"

msgid "Paragraph review note"
msgstr "段落审阅说明"

msgid "Content Support groups"
msgstr "内容支持分组"

msgid "Title and Summary Helper"
msgstr "标题与摘要助手"

msgid "Suggest reviewable titles, a short excerpt, and a direct answer summary from the supplied topic or draft."
msgstr "根据提供的主题或草稿，建议可审阅标题、简短摘要和直接回答摘要。"

msgid "Suggest titles and summary"
msgstr "建议标题和摘要"

msgid "Review title options before replacing the post title."
msgstr "替换文章标题前先审阅标题选项。"

msgid "Use the outline as planning notes; it does not write the article body."
msgstr "把大纲作为规划笔记使用；它不会写入文章正文。"

msgid "Use SEO, AEO, GEO, and proposal-field suggestions as review notes only."
msgstr "仅把 SEO、AEO、GEO 和提案字段建议作为审阅笔记使用。"

msgid "Review ALT and caption suggestions against the actual image before any media edit."
msgstr "编辑任何媒体字段前，先对照实际图片审阅 ALT 和说明文字建议。"

msgid "Hosted AI suggestion"
msgstr "托管 AI 建议"

msgid "No title suggestions returned."
msgstr "没有返回标题建议。"

msgid "No outline suggestions returned."
msgstr "没有返回大纲建议。"

msgid "No paragraph review notes returned."
msgstr "没有返回段落审阅建议。"

msgid "Outline Helper"
msgstr "大纲助手"

msgid "Turn a topic, brief, or rough notes into a compact outline that an editor can expand manually."
msgstr "把主题、简报或粗略笔记转换成编辑可手动扩展的精简大纲。"

msgid "Build outline"
msgstr "生成大纲"

msgid "Polish Helper"
msgstr "润色助手"

msgid "Rewrite a short draft section for clarity and tone while keeping the original meaning reviewable."
msgstr "在保持原意可审阅的前提下，重写一小段草稿以改善清晰度和语气。"

msgid "Polish draft"
msgstr "润色草稿"

msgid "Everyday Support"
msgstr "日常支持"

msgid "SEO/AEO/GEO, metadata, links, image candidates, and publish readiness."
msgstr "SEO/AEO/GEO、元数据、链接、图片候选和发布就绪检查。"

msgid "Build SEO, AEO, GEO, taxonomy, and proposal-field suggestions with saved context and Site Knowledge when available."
msgstr "使用已保存上下文，并在可用时结合站点知识，生成 SEO、AEO、GEO、分类和提案字段建议。"

msgid "Build suggestions"
msgstr "生成建议"

msgid "Check source coverage, duplicate risk, missing terms, excerpt, and media readiness against current site context."
msgstr "根据当前站点上下文检查来源覆盖、重复风险、缺失分类标签、摘要和媒体就绪情况。"

msgid "Run preflight"
msgstr "运行预检"

msgid "Summary and Terms Optimization"
msgstr "摘要和分类标签优化"

msgid "Review Generate and apply summary, Recommend and apply tags, Recommend categories, and Create new tags and assign candidates as Core handoff actions without writing WordPress data."
msgstr "审阅“生成并应用摘要”、“推荐并应用标签”、“推荐分类”和“创建新标签并分配”等 Core 交接候选操作，不直接写入 WordPress 数据。"

msgid "Optimize metadata"
msgstr "优化元数据"

msgid "Taxonomy/Tag Candidates"
msgstr "分类/标签候选"

msgid "Suggest matching existing categories and tags from the supplied draft context."
msgstr "根据提供的草稿上下文建议匹配的已有分类和标签。"

msgid "Existing Taxonomy/Tag Candidates"
msgstr "已有分类/标签候选"

msgid "Suggest matching existing categories and tags from the supplied article, selected text, or topic context."
msgstr "根据提供的文章、选中文本或主题上下文，建议匹配的已有分类和标签。"

msgid "Find terms"
msgstr "查找分类标签"

msgid "Find existing terms"
msgstr "查找已有分类标签"

msgid "Use Cloud-managed Site Knowledge to find related public content for operator-reviewed links."
msgstr "使用 Cloud 托管站点知识查找相关公开内容，供运营者审阅链接。"

msgid "Find links"
msgstr "查找链接"

msgid "Image Candidates"
msgstr "图片候选"

msgid "Find image-source candidates for featured or inline use. Import still requires a governed handoff."
msgstr "查找用于特色图或正文图片的图片来源候选。导入仍需要治理交接。"

msgid "Find images"
msgstr "查找图片"

msgid "Fallback Bundles"
msgstr "备用工具"

msgid "Advanced fallback packages; not the daily writing path."
msgstr "高级备用包；不是日常写作路径。"

msgid "Combined artifacts for reviewed local workbench cases."
msgstr "低频使用的准备材料和交接包，不是日常写作入口。"

msgid "Article topic"
msgstr "要规划的文章主题"

msgid "Build bundle"
msgstr "生成准备材料"

msgid "Article Assistant Fallback"
msgstr "文章助手备用工作台"

msgid "Assemble one local workbench artifact from support abilities and an optional reviewed draft; it does not write the article body."
msgstr "把主题、参考资料和可选的已审阅草稿整理成一个本地工作台结果；不会自动写文章正文。"

msgid "Advanced fallback workbench for existing support artifacts and an optional reviewed draft; it does not write the article body."
msgstr "面向已有支持产物和可选已审阅草稿的高级备用工作台；不会写入文章正文。"

msgid "Governed Handoffs"
msgstr "治理交接"

msgid "Core-ready plans after reviewed editor choices exist."
msgstr "在编辑已审阅选择后生成 Core 就绪计划。"

msgid "Use after reviewed draft, selected image, or editor choices exist."
msgstr "在已有已审阅草稿、已选图片或编辑器选择后使用。"

msgid "Media"
msgstr "媒体"

msgid "Media briefs, image adoption plans, and existing-image optimization."
msgstr "媒体简报、图片采用计划和现有图片优化。"

msgid "Start here for existing-image optimization and bounded media planning."
msgstr "从这里开始处理现有图片优化和有限媒体规划。"

msgid "Media Brief"
msgstr "媒体简报"

msgid "Use an existing post id to plan image prompts and media SEO actions."
msgstr "使用已有文章 ID 规划图片提示词和媒体 SEO 操作。"

msgid "Post ID"
msgstr "文章 ID"

msgid "Plan media"
msgstr "规划媒体"

msgid "Tool actions"
msgstr "工具操作"

msgid "Hosted AI route"
msgstr "托管 AI 路由"

msgid "Toolbox sends one lightweight draft-support request through the Cloud hosted runtime when the site is connected. The result is a reviewable suggestion, not a finished article."
msgstr "站点连接后，Toolbox 会通过 Cloud 托管运行时发送一个轻量草稿支持请求。结果是可审阅建议，不是成稿文章。"

msgid "Connect Cloud Addon before running hosted AI support."
msgstr "运行托管 AI 支持前请先连接 Cloud Addon。"

msgid "Fixed support flow"
msgstr "固定支持流程"

msgid "This runs one bounded suggestion flow from the supplied draft context. It does not write posts, assign terms, insert links, import media, or publish."
msgstr "这会根据提供的草稿上下文运行一个有边界的建议流程。它不会写文章、分配分类标签、插入链接、导入媒体或发布。"

msgid "This runs one bounded suggestion flow from the supplied article, selected text, topic, or brief. It does not write posts, assign terms, insert links, import media, or publish."
msgstr "这会根据提供的文章、选中文本、主题或简报运行一个有边界的建议流程。它不会写文章、分配分类标签、插入链接、导入媒体或发布。"

msgid "Input scope"
msgstr "输入范围"

msgid "Auto: selected text when present, otherwise full article"
msgstr "自动：有选中文本时使用选中文本，否则使用全文"

msgid "Full article context"
msgstr "全文上下文"

msgid "Selected text or supplied snippet"
msgstr "选中文本或提供的片段"

msgid "Topic or short brief only"
msgstr "仅主题或简短简报"

msgid "Post ID (optional)"
msgstr "文章 ID（可选）"

